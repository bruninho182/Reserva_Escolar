{
  "manifest_version": 3,
  "name": "Reserva Escolar - Automador Integrador",
  "version": "1.0",
  "description": "Automação de preenchimento de reservas através de cópia e colagem de dados estruturados.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
    "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.reservaescolar.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}